# Copy to .env (which is gitignored) and fill in. NEVER commit the real key.
# OneSignal dashboard → Settings → Keys & IDs → "REST API Key".
ONESIGNAL_REST_API_KEY=

# Optional overrides (sensible defaults are built in):
# ONESIGNAL_APP_ID=555513b3-ba92-4a62-b7b8-cf7193076411
# ONESIGNAL_SEGMENT=Total Subscriptions   # everyone; or "Active Subscriptions"
# ONESIGNAL_AUTH_SCHEME=Key        # "Key" for os_v2_… keys, "Basic" for legacy keys
# CHEERDJ_SITE_URL=https://dc.thecheerdj.com
